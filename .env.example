# ===== Slip Bot — ตัวอย่างไฟล์ตั้งค่า =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (หรือคัดลอก .env จากเครื่องหลักมาทั้งไฟล์)

# Telegram
TELEGRAM_BOT_TOKEN=

# Google Sheets / Drive (เลือกอย่างใดอย่างหนึ่ง: ใช้ไฟล์ credentials.json + tokens/ หรือใส่เป็น JSON ตรงนี้)
SPREADSHEET_ID=
# GOOGLE_CREDENTIALS_JSON=
# GOOGLE_TOKEN_JSON=

# OCR providers (Gemini หลัก, ที่เหลือสำรอง)
GEMINI_API_KEY=
OPENAI_API_KEY=
TYPHOON_API_KEY=
OCR_MODEL=gemini-2.5-flash
OCR_FALLBACK_1=typhoon-ocr
OCR_FALLBACK_2=gpt-4o

# Dashboard login
DASHBOARD_USER=admin
DASHBOARD_PASS=
DASHBOARD_PIN=

# การแจ้งเตือน / สิทธิ์
SUMMARY_CHAT_ID=
ALLOWED_CHAT_IDS=

# เวลา (cron) — ไม่บังคับ
# SUMMARY_TIME=59 23 * * *
# BACKUP_TIME=30 0 * * *

# เทียบยอดกับธนาคารจริง (debittrans) — ดึงรายการธนาคารมาจับคู่กับสลิปที่บันทึก
# DEBIT_API_URL=https://debittrans.vercel.app/api/public/transactions
# DEBIT_API_KEY=
